# Optional model overrides. Defaults are Gemini 2.x models compatible with Google Search.
ROOT_DEEP_WEB_RESEARCH_PLANNER_MODEL=gemini-2.5-flash
ROOT_DEEP_WEB_RESEARCH_SEARCH_MODEL=gemini-2.5-flash
ROOT_DEEP_WEB_RESEARCH_EVALUATOR_MODEL=gemini-2.5-flash

# Guardrail defaults.
ROOT_DEEP_WEB_RESEARCH_MAX_ITERATIONS=2
ROOT_DEEP_WEB_RESEARCH_MAX_BUDGET_UNITS=6

# Choose either AI Studio API key or Vertex AI environment variables.
# Do not commit real secrets.
# GOOGLE_API_KEY=your_api_key_here
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_CLOUD_LOCATION=global
